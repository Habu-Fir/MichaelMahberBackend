{
    "compilerOptions": {
        "target": "ES2020",
        "module": "node16",
        "lib": [
            "ES2020"
        ],
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "moduleResolution": "node16"
    },
    "include": [
        "src/**/*",
        "test-deployment.js"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}